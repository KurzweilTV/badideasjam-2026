[sub_resource type="GDScript" id="GDScript_wbtgf"]
resource_name = "BreathSounds"
script/source = "extends ProgressBar

@export var character: Player
@onready var animation_player: AnimationPlayer = $AnimationPlayer
@onready var audio_stream_player: AudioStreamPlayer = $BreathSound

func sprint_animation(status: bool) -> void:
	if status:
		animation_player.play(\"sprinting\")
	else:
		animation_player.stop(true)

func breath() -> void:
	if character.is_talking:
		print(\"character.is_talking: %s\" % str(character.is_talking))
		return
	audio_stream_player.pitch_scale = (randf_range(0.95, 1.00))
	audio_stream_player.play()
	
"

